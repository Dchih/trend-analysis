{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://productradar.local/schemas/tasks/collect-task.schema.json",
  "title": "CollectTask",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "task_id": {
      "type": "string",
      "minLength": 1
    },
    "keyword": {
      "type": "string",
      "minLength": 1
    },
    "platforms": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "enum": ["youtube"]
      }
    },
    "trigger": {
      "type": "string",
      "enum": ["manual_search", "scheduled_refresh"]
    },
    "requested_at": {
      "type": "string",
      "format": "date-time"
    },
    "time_range": {
      "type": "string",
      "enum": ["7d", "30d", "90d"]
    },
    "priority": {
      "type": "integer",
      "minimum": 1,
      "maximum": 10
    },
    "status": {
      "type": "string",
      "enum": ["pending", "running", "succeeded", "failed", "partial_success"]
    }
  },
  "required": [
    "task_id",
    "keyword",
    "platforms",
    "trigger",
    "requested_at",
    "time_range",
    "priority"
  ]
}
